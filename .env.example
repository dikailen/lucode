DEEPSEEK_API_KEY=your_deepseek_flash_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

DEEPSEEK_pro_API_KEY=your_deepseek_pro_api_key
DEEPSEEK_BASE_pro_URL=https://api.deepseek.com
DEEPSEEK_pro_MODEL=deepseek-v4-pro

MIMO_API_KEY=your_mimo_api_key
MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
# 推荐：同一个 MiMo key / base_url 下直接注册多个版本，启动时会自动展开成多个模型。
# 例如会生成 mimo_v25_model、mimo_v25_pro_model 这样的模型 id。
MIMO_API_MODELS=mimo_v25:mimo-v2.5,mimo_v25_pro:mimo-v2.5-pro

# 可选：新增模型可以用 MODEL_<名字>_* 格式自动注册进模型图书馆。
# 例如添加一个通用模型：
# MODEL_QWEN_API_KEY=your_qwen_api_key
# MODEL_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_QWEN_MODEL=qwen-plus
# MODEL_QWEN_DISPLAY_NAME=Qwen Plus
# MODEL_QWEN_PROVIDER=qwen
# MODEL_QWEN_STRENGTHS=通用问答,中文解释,联网资料整理
# MODEL_QWEN_BEST_FOR_SKILLS=project_explorer,humanizer_zh
# MODEL_QWEN_COST_LEVEL=medium
# MODEL_QWEN_REASONING_LEVEL=medium
# MODEL_QWEN_BACKEND=openai_compatible

# 可选：同一个 API key / 同一个 base_url 下挂多个模型版本。
# 这样不用每个模型都重复写 API key 和请求地址；启动刷新图书馆时会自动展开成多个模型。
# 写法一：别名:真实模型名，最终模型 id 会是 siliconflow_qwen_plus_model 这种格式。
# MODEL_SILICONFLOW_API_KEY=your_siliconflow_api_key
# MODEL_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# MODEL_SILICONFLOW_BACKEND=openai_compatible
# MODEL_SILICONFLOW_PROVIDER=siliconflow
# MODEL_SILICONFLOW_DISPLAY_PREFIX=硅基流动
# MODEL_SILICONFLOW_MODELS=qwen_plus:Qwen/Qwen3-8B,deepseek_r1:deepseek-ai/DeepSeek-R1
# MODEL_SILICONFLOW_STRENGTHS=通用问答,代码解释,中文解释
# MODEL_SILICONFLOW_BEST_FOR_SKILLS=project_explorer,jpc_now_skill
# MODEL_SILICONFLOW_COST_LEVEL=medium
# MODEL_SILICONFLOW_REASONING_LEVEL=medium
# MODEL_SILICONFLOW_SUPPORTS_TOOLS=true
#
# 写法二：也可以只写真实模型名，系统会自动生成别名。
# MODEL_SILICONFLOW_MODELS=Qwen/Qwen3-8B,deepseek-ai/DeepSeek-V3

# 可选：本地 Ollama 模型。Ollama 后端不需要 API key。
# MODEL_LOCAL_BACKEND=ollama
# MODEL_LOCAL_BASE_URL=http://localhost:11434
# MODEL_LOCAL_MODEL=qwen3:8b
# MODEL_LOCAL_DISPLAY_NAME=本地 Qwen3 8B
# MODEL_LOCAL_PROVIDER=ollama
# MODEL_LOCAL_STRENGTHS=本地优先,代码不出网,低成本
# MODEL_LOCAL_BEST_FOR_SKILLS=project_explorer,jpc_now_skill
# MODEL_LOCAL_COST_LEVEL=low
# MODEL_LOCAL_REASONING_LEVEL=medium
# 可选：手动声明该模型是否支持 tools/function calling。未声明时会自动探测/保守猜测。
# MODEL_LOCAL_SUPPORTS_TOOLS=true

# 可选：本地模型能力探测。启动刷新图书馆时会短超时探测本地模型是否支持普通聊天、JSON、tools。
# 默认 background：终端先启动，探测在后台刷新缓存；sync 会阻塞启动等待探测；off 跳过探测。
# MODEL_PROBE_STARTUP_MODE=background
# MODEL_PROBE_ENABLED=true
# MODEL_PROBE_LOCAL_ONLY=true
# MODEL_PROBE_TIMEOUT_SECONDS=2
# MODEL_PROBE_CACHE_TTL_SECONDS=86400
# MODEL_PROBE_FAILURE_TTL_SECONDS=300

# 可选：本地 llama.cpp / GGUF 模型。当前先作为后端元数据预留，后续接入原生推理。
# MODEL_GGUF_BACKEND=llama_cpp
# MODEL_GGUF_BASE_URL=local-llama-cpp
# MODEL_GGUF_MODEL=local-gguf-model
# MODEL_GGUF_MODEL_PATH=D:\models\qwen.gguf

# 可选：MCP 读取预算。数值越大，Agent 能读更多文件，但 token 成本也会升高。
# MCP_FS_MAX_READ_CALLS=10
# MCP_FS_MAX_FILES_PER_CALL=5
# MCP_FS_MAX_CHARS_PER_FILE=6000
# MCP_FS_MAX_TOTAL_CHARS=30000
# MCP_FS_MAX_TREE_DEPTH=3
# MCP_FS_MAX_TREE_ENTRIES=350

# 可选：写入/删除安全限制。
# strict sha 默认开启：覆盖、替换、删除已有文件或 apply patch 时，必须先读取文件并传入当前 sha256。
# 这样可以防止 Agent 基于旧内容改文件，降低并发或上下文过期导致的覆盖风险。
# WORKSPACE_EDIT_STRICT_SHA256=1
# WORKSPACE_EDIT_MAX_BACKUP_BYTES=52428800
# WORKSPACE_EDIT_MAX_BACKUP_FILES=5000
# SAFE_DELETE_MAX_BACKUP_BYTES=52428800
# SAFE_DELETE_MAX_BACKUP_FILES=5000

# 可选：代码定位索引预算。索引缓存在项目内 .agent_cache/，不会进入 git。
# CODE_LOCATOR_MAX_FILES=700
# CODE_LOCATOR_MAX_FILE_BYTES=300000

# 可选：联网搜索 Provider。
# duckduckgo_html 是免费 fallback；brave / bing / serpapi 需要对应 API Key。
# 搜索结果会按 官方文档 > 官方 GitHub > 文档站 > 包仓库 > GitHub > 普通网页 > 社区文章 排序。
# WEB_SEARCH_PROVIDER=duckduckgo_html
# WEB_SEARCH_PROVIDER=brave
# WEB_SEARCH_API_KEY=your_search_api_key
# BRAVE_SEARCH_API_KEY=your_brave_key
# BING_SEARCH_API_KEY=your_bing_key
# SERPAPI_API_KEY=your_serpapi_key
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT_SECONDS=15

# 可选：编辑任务完成后的验证命令。多条命令可以按多行写入环境变量。
# AGENTS_VERIFY_COMMANDS="D:\develop\Data_anaconda2024\envs\agents-demo\python.exe tests\run_regression.py"

# 可选：单轮执行超时，避免模型或工具卡住后终端长期无响应。
# AGENTS_TURN_TIMEOUT_SECONDS=180

# 可选：是否开启可见答案流式输出。只输出模型可见回答，不输出隐藏思考链。
# 如果某个第三方兼容接口流式不稳定，可以设为 0 回到普通输出。
# AGENTS_STREAM_OUTPUT=1

# 可选：三脑模型偏好和前置优化开关。
# 主脑负责调度规划；前置优化副脑负责把用户问题整理清楚；汇总副脑负责多 Agent 结果整合。
# 如果你不写下面 3 个优先级配置，系统会根据当前 .env 里已经注册成功的模型自动生成默认优先级。
# 只有你想手动指定顺序时，才需要填写这些配置。
# 默认关闭前置优化副脑；需要启用时取消下一行注释并设为 true。
# AGENTS_QUERY_REFINER_ENABLED=true
# AGENTS_QUERY_REFINER_MODEL_PRIORITY=deepseek_v4_flash_model,mimo_v25_pro_model
# AGENTS_ORCHESTRATOR_MODEL_PRIORITY=deepseek_v4_pro_model,mimo_v25_pro_model
# AGENTS_FINAL_SYNTHESIZER_MODEL_PRIORITY=deepseek_v4_pro_model,mimo_v25_pro_model

# 可选：执行模式。
# solo：默认单模型工具 Agent，可读写文件、联网、跑命令和测试，但不创建多 Agent。
# serial：显式多 Agent 串行工程模式，由主脑规划，多专家按顺序处理。
# full：显式高级并行多 Agent，通过安全门后才允许并行。
# AGENTS_EXECUTION_MODE=solo

# 可选：隐私模式。
# offline：禁止联网搜索，禁止云端模型，只允许本地 Ollama / llama.cpp。
# local_first：优先本地模型，本地不可用时再使用已配置云端模型。
# cloud_allowed：允许云端模型和联网搜索。
# AGENTS_PRIVACY_MODE=local_first
# offline 模式下联网 MCP 的策略：warn 会提示风险但允许用户审批后使用；block 会彻底禁止。
# AGENTS_OFFLINE_NETWORK_MCP_POLICY=warn
